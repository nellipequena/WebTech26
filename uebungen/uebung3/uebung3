<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Uebung 3</title>
</head>

    <style>
        header {
            background-color: rgb(9, 116, 7);
            color: white;
            padding: 10px;
            text-align: center;
            padding: 1vw; 
        }
        
        .wrapper {
            display: grid;
            grid-template-columns: repeat(1, 1fr); /*--> hier wird Mobile-First definiert*/
            margin: 2%; /* Kacheln rücken unter den Header-Block*/
            gap: 4vw;
        }

        .citycard {
            text-align: center;
            display: grid;
            align-items: center;
            padding-top: 20px;  /* nur oben */
            box-shadow: rgba(50, 50, 93, 0.25) 0px 13px 27px -5px, rgba(0, 0, 0, 0.3) 0px 8px 16px -8px;        
        }
        
        .citycard:hover {
            box-shadow: rgba(125, 125, 247, 0.25) 0px 30px 60px -12px inset, rgba(0, 0, 0, 0.3) 0px 18px 36px -18px inset;
            font-weight: bold;
        }

        .cityimage {
            height: 250px;      /* feste Höhe für den Bild-Container */
            overflow: hidden;   /* verhindert, dass das Bild herausragt */
        }

        .cityimage img {
            width: 100%;
            height: 100%;
            object-fit: contain;  /* Bild vollständig sichtbar */
        }

        .cityname {
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 0;
        }

        .cityname p {
            margin: 0;  /* <-- wichtig! Standard-margin des <p> entfernen */
        }

        /*.citycard img {
            width: 100%;
            height: 250px;
            object-fit: cover; /* Bild wird zugeschnitten, nicht verzerrt
        }*/

        /*@media screen and (max-width: 600px) {
            .wrapper {
                grid-template-columns: 1fr;
            }
        } --> Nicht nötig, wenn bei .wrapper Mobil-First angewendet wird ("repeat(1,1fr)")*/

        @media screen and (min-width: 600px) {
            .wrapper {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media screen and (min-width: 800px) {
            .wrapper {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media screen and (min-width: 1200px) {
            .wrapper {
                grid-template-columns: repeat(4, 1fr);
            }
        }
    </style>

<body>
